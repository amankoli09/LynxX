{
  "name": "lynxx-wallet-sdk",
  "version": "0.1.0",
  "description": "SDK for integrating LynxX into your dApps",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "lint": "eslint .",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.14.9",
    "eslint": "^10.6.0",
    "tsup": "^8.1.0",
    "typescript": "^5.5.2",
    "typescript-eslint": "^8.63.0",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "@stellar/stellar-sdk": ">=10.0.0"
  }
}
